            "sampleData": {},
            "sourceCode": {
              "code": "export const code = async (inputs) => {\n  const payload = inputs.payload;\n  if (!payload) {\n    return { type: 'ERROR', message: 'No payload' };\n  }\n\n  // 1. Check for GET verification request (WhatsApp)\n  const queryParams = payload.queryParams || {};\n  const method = payload.method || '';\n\n  if (method.toUpperCase() === 'GET' || queryParams['hub.mode'] === 'subscribe') {\n    const mode = queryParams['hub.mode'];\n    const token = queryParams['hub.verify_token'];\n    const challenge = queryParams['hub.challenge'];\n\n    if (mode === 'subscribe' && token === 'cliniccare_secret_2026') {\n      return {\n        type: 'GET_VERIFICATION',\n        status: 200,\n        challenge: challenge\n      };\n    } else {\n      return {\n        type: 'GET_VERIFICATION',\n        status: 403,\n        challenge: 'Verification failed'\n      };\n    }\n  }\n\n  // 2. Handle POST payload\n  const body = payload.body || {};\n  const entry = body.entry || [];\n  if (entry.length === 0) {\n    return { type: 'POST_IGNORE', message: 'Not a whatsapp message' };\n  }\n  const changes = entry[0].changes || [];\n  if (changes.length === 0) {\n    return { type: 'POST_IGNORE', message: 'No changes' };\n  }\n  const value = changes[0].value || {};\n  \n  if (value.statuses && value.statuses.length > 0) {\n    const statusObj = value.statuses[0];\n    return {\n      type: 'STATUS_UPDATE',\n      msgId: statusObj.id,\n      status: statusObj.status,\n      phone: statusObj.recipient_id,\n      timestamp: statusObj.timestamp\n    };\n  }\n\n  if (value.messages && value.messages.length > 0) {\n    const msgObj = value.messages[0];\n    const contactObj = value.contacts?.[0] || {};\n    return {\n      type: 'INCOMING_MESSAGE',\n      phone: msgObj.from,\n      msgId: msgObj.id,\n      text: msgObj.text?.body || '',\n      profileName: contactObj.profile?.name || '',\n      timestamp: msgObj.timestamp\n    };\n  }\n\n  return { type: 'UNKNOWN', payload: payload };\n};",
              "packageJson": "{}"
