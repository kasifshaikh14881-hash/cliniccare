                "name": "step_4_prepare",
                "skip": false,
                "type": "CODE",
                "valid": true,
                "settings": {
                  "input": {
                    "clinics": "{{step_2_get_clinics}}",
                    "patient": "{{step_3_loop['item']['values']}}",
                    "patientRow": "{{step_3_loop['item']['row']}}"
                  },
                  "sampleData": {},
                  "sourceCode": {
                    "code": "export const code = async (inputs) => {\n  // patients columns:\n  // A=patient_id B=corr_id C=clinic_id D=patient_name E=phone_raw F=phone_cleaned\n  // G=followup_date H=status I=processing_lock J=sentiment K=delivery_status\n  // L=delivered_at M=read_at N=replied_at O=review_requested P=review_sent_at ...\n  const pv = inputs.patient || {};\n  const patientRow = inputs.patientRow || '';\n  const clinics = Array.isArray(inputs.clinics) ? inputs.clinics : [];\n\n  const clinicId        = pv['C'] || '';\n  const phone           = pv['F'] || '';\n  const name            = pv['D'] || 'Patient';\n  const corrId          = pv['B'] || '';\n  const reviewRequested = (pv['O'] || '').toString().toUpperCase();\n  const reviewSentAt    = pv['P'] || '';\n  const repliedAt       = pv['N'] || '';\n\n  // IDEMPOTENCY: if review was already SENT (review_sent_at filled), skip\n  if (reviewSentAt && reviewSentAt.trim() !== '') {\n    return { skip: true, reason: 'review_already_sent' };\n  }\n\n  // 30-minute delay check from time of reply\n  if (repliedAt) {\n    const minutesPassed = (Date.now() - new Date(repliedAt).getTime()) / (1000 * 60);\n    if (minutesPassed < 30) {\n      return { skip: true, reason: 'too_soon', minutesPassed: Math.round(minutesPassed) };\n    }\n  }\n\n  // Find clinic\n  // clinics columns: A=clinic_id B=clinic_name C=wa_token D=phone_number_id\n  // E=google_review_link F=owner_phone G=owner_email H=review_delay_m I=is_active\n  const clinic = clinics.find(c => {\n    const cv = c['values'] || c;\n    return (cv['A'] || '').toString().trim() === clinicId.trim();\n  });\n\n  if (!clinic) {\n    return { skip: true, reason: 'clinic_not_found', clinicId };\n  }\n\n  const cv = clinic['values'] || clinic;\n  const waToken       = cv['C'] || '';\n  const phoneNumberId = cv['D'] || '';\n  const reviewLink    = cv['E'] || '';\n\n  if (!waToken || !phoneNumberId || !reviewLink) {\n    return { skip: true, reason: 'clinic_credentials_incomplete', clinicId };\n  }\n\n  return {\n    skip: false,\n    phone, name, corrId, clinicId,\n    waToken, phoneNumberId, reviewLink,\n    patientRow\n  };\n};",
                    "packageJson": "{}"
                  },
