                  "sampleData": {},
                  "sourceCode": {
                    "code": "\nexport const code = async (inputs) => {\n  const item = inputs.item;\n  const clinics = inputs.clinics;\n  const clinicId = item.values.B; // send_queue col B = clinic_id\n  \n  // Find matching clinic\n  const clinic = clinics.find(c => c.values && c.values.A === clinicId);\n  \n  if (!clinic) {\n    return { skip: true, reason: 'Clinic not found: ' + clinicId };\n  }\n  \n  return {\n    skip: false,\n    waToken: clinic.values.C,         // wa_token\n    phoneNumberId: clinic.values.D,   // phone_number_id\n    phone: item.values.D,             // patient phone (send_queue col D)\n    patientName: item.values.E,       // patient name (send_queue col E)\n    corrId: item.values.A,            // corr_id (send_queue col A)\n    clinicId: clinicId,\n    patientRow: item.row,\n    clinicName: clinic.values.B,\n  };\n};\n",
                    "packageJson": "{}"
                  },
                  "errorHandlingOptions": {
                    "retryOnFailure": {
                      "value": false
                    },
                    "continueOnFailure": {
                      "value": true
                    }
                  }
                },
