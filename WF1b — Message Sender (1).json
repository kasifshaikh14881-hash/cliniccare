                          "sampleData": {},
                          "sourceCode": {
                            "code": "\nexport const code = async (inputs) => {\n  const resp = inputs.httpResp;\n  if (!resp) return { ok: true };\n  \n  const status = resp.status || 200;\n  const body = typeof resp.body === 'string' ? JSON.parse(resp.body || '{}') : (resp.body || {});\n  const errCode = body?.error?.code;\n  \n  // Token expired or unauthorized\n  if (errCode === 190 || status === 401) {\n    return { ok: false, issue: 'TOKEN_EXPIRED', skip_update: true };\n  }\n  // Rate limit\n  if (errCode === 429 || status === 429) {\n    return { ok: false, issue: 'RATE_LIMITED', skip_update: true };\n  }\n  // Not on WhatsApp\n  if (errCode === 131026) {\n    return { ok: false, issue: 'NOT_ON_WHATSAPP', skip_update: false };\n  }\n  // Success - has message ID\n  const msgId = body?.messages?.[0]?.id || '';\n  return { ok: !!msgId || status === 200, msgId, issue: null, skip_update: false };\n};\n",
                            "packageJson": "{}"
                          },
