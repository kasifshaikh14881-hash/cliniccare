                    "patientRow": "{{step_3_loop['item']['row']}}"
                  },
                  "sampleData": {},
                  "sourceCode": {
                    "code": "export const code = async (inputs) => {\n  // patients columns:\n  // A=patient_id B=corr_id C=clinic_id D=patient_name E=phone_raw F=phone_cleaned\n  // G=followup_date H=status I=processing_lock J=sentiment ...\n  // Q=alert_sent R=alert_sent_at S=opted_out T=registered_at U=wf_version\n  const pv = inputs.patient || {};\n  const patientRow = inputs.patientRow || '';\n  const clinics = Array.isArray(inputs.clinics) ? inputs.clinics : [];\n\n  const clinicId     = pv['C'] || '';\n  const phone        = pv['F'] || '';\n  const name         = pv['D'] || 'Patient';\n  const corrId       = pv['B'] || '';\n  const followupDate = pv['G'] || '';\n  const alertSent    = (pv['Q'] || '').toString().toUpperCase();\n\n  // CRITICAL IDEMPOTENCY CHECK: alert already sent means WF4 handled it\n  if (alertSent === 'TRUE') {\n    return { skip: true, reason: 'alert_already_sent_by_wf4' };\n  }\n\n  // Find clinic\n  // clinics: A=clinic_id B=clinic_name C=wa_token D=phone_number_id\n  //          E=google_review_link F=owner_phone G=owner_email H=review_delay_m I=is_active\n  const clinic = clinics.find(c => {\n    const cv = c['values'] || c;\n    return (cv['A'] || '').toString().trim() === clinicId.trim();\n  });\n\n  if (!clinic) {\n    return { skip: true, reason: 'clinic_not_found', clinicId };\n  }\n\n  const cv = clinic['values'] || clinic;\n  const waToken       = cv['C'] || '';\n  const phoneNumberId = cv['D'] || '';\n  const ownerPhone    = cv['F'] || '';\n  const clinicName    = cv['B'] || 'Clinic';\n\n  if (!waToken || !phoneNumberId || !ownerPhone) {\n    return { skip: true, reason: 'clinic_credentials_incomplete', clinicId };\n  }\n\n  return {\n    skip: false,\n    phone, name, corrId, clinicId, clinicName,\n    waToken, phoneNumberId, ownerPhone,\n    followupDate, patientRow\n  };\n};",
                    "packageJson": "{}"
                  },
